---
/**
 * The Coco chat — ONE DOM instance for the whole page.
 * Desktop ≥1280px: lives in #chat-rail-slot (sticky rail, never scrolls with content).
 * Below 1280px: lives inside the bottom sheet, opened from the dock.
 * Any element with [data-coco-q] sends that question; [data-coco-open] opens the chat.
 */
import { SITE } from "../data/site";

interface Chip { label: string; q: string; }
interface Props { chips?: Chip[]; }
const defaultChips: Chip[] = [
  { label: "🏖️ Family beach?", q: "Best beach for families with young kids on Koh Samui?" },
  { label: "🤿 Dive Sail Rock", q: "How do I get to Sail Rock for a diving trip?" },
  { label: "🍽️ Where to eat", q: "Best restaurants in Koh Samui — romantic, seafood, local Thai?" },
  { label: "🌧️ Rainy day", q: "What to do in Koh Samui when it rains?" },
];
const { chips = defaultChips } = Astro.props;
---

<!-- ══ CHAT (relocatable) ══ -->
<div id="coco-chat" class="flex h-full min-h-0 flex-col overflow-hidden rounded-2xl border hairline bg-ink-2/95 shadow-[0_20px_60px_rgba(0,0,0,.45)]">
  <!-- Head -->
  <div class="flex shrink-0 items-center gap-3 border-b hairline px-4 py-3">
    <div class="grid size-9 shrink-0 place-items-center rounded-xl bg-gradient-to-br from-teal to-foam text-lg" aria-hidden="true">🌴</div>
    <div class="min-w-0">
      <div class="text-[14px] font-bold text-white">Coco</div>
      <div class="flex items-center gap-1.5 text-[11px] text-foam">
        <span class="inline-block size-1.5 rounded-full bg-foam motion-safe:animate-pulse" aria-hidden="true"></span>
        Online — always here
      </div>
    </div>
    <div class="ml-auto hidden text-[10.5px] tracking-wide text-white/35 min-[400px]:block">{SITE.languages.join(" · ")}</div>
    <button type="button" id="coco-sheet-close" class="ml-1 hidden size-9 shrink-0 cursor-pointer place-items-center rounded-lg text-lg text-white/60 hover:bg-white/8 hover:text-white" aria-label="Close chat">✕</button>
  </div>

  <!-- Messages -->
  <div id="coco-msgs" class="flex min-h-0 flex-1 flex-col gap-2.5 overflow-y-auto scroll-smooth px-4 py-4" aria-live="polite" aria-label="Conversation with Coco">
    <div class="msg-coco">Sawadee kha! 🌺 I'm Coco, your AI travel guide for Koh Samui.

Hotels, a dive trip to Sail Rock, the best street food, how to reach Ang Thong — ask me anything, in your own language. 🌴</div>
  </div>

  <!-- Contextual chips -->
  <div id="coco-chips" class="flex shrink-0 gap-2 overflow-x-auto px-4 pb-2.5 [scrollbar-width:none]">
    {chips.map((c) => (
      <button type="button" data-coco-q={c.q} class="shrink-0 cursor-pointer rounded-full border hairline bg-white/4 px-3.5 py-2 text-[12px] font-medium text-white/75 transition hover:border-foam/40 hover:bg-white/8 hover:text-white">{c.label}</button>
    ))}
  </div>

  <!-- Input -->
  <div class="shrink-0 border-t hairline px-3.5 pb-3 pt-3">
    <form id="coco-form" class="flex items-end gap-2">
      <label for="coco-input" class="sr-only">Ask Coco anything about Koh Samui</label>
      <textarea id="coco-input" rows="1" placeholder="Ask me anything about Koh Samui…" enterkeyhint="send"
        class="max-h-28 min-h-11 flex-1 resize-none rounded-xl border hairline bg-white/5 px-3.5 py-2.5 text-[16px] text-white placeholder:text-white/30 focus:border-teal focus:outline-none"></textarea>
      <button type="submit" id="coco-send" class="grid size-11 shrink-0 cursor-pointer place-items-center rounded-xl bg-teal text-white transition hover:bg-teal-deep disabled:opacity-40" aria-label="Send message">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 11.5 21 3l-8.5 18-2.4-7.1L3 11.5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
      </button>
    </form>
    <p class="mt-2 px-1 text-center text-[10.5px] leading-snug text-white/30">
      AI answers may be wrong; prices indicative — confirm with operators. Not safety advice. Some links are affiliate links.
      <a href="/terms" class="text-foam/70 hover:text-foam">Terms</a> · <a href="/privacy" class="text-foam/70 hover:text-foam">Privacy</a>
    </p>
  </div>
</div>

<script>
  // ── Single-instance chat client (rail ⇄ sheet relocation, /api/chat) ──
  const $ = (id: string) => document.getElementById(id)!;
  const chat = $("coco-chat");
  const msgs = $("coco-msgs");
  const input = $("coco-input") as HTMLTextAreaElement;
  const form = $("coco-form") as HTMLFormElement;
  const sendBtn = $("coco-send") as HTMLButtonElement;

  // White-label param persists across the multi-page site.
  const urlHotel = new URLSearchParams(location.search).get("hotel");
  if (urlHotel) sessionStorage.setItem("coco-hotel", urlHotel);
  const hotel = urlHotel || sessionStorage.getItem("coco-hotel") || undefined;

  const history: { role: "user" | "assistant"; content: string }[] = [];

  const esc = (s: string) => s.replace(/[&<>"']/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c]!));
  function render(text: string): string {
    let h = esc(text);
    h = h.replace(/\*\*([^*]+)\*\*/g, "<strong>$1</strong>");
    h = h.replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener nofollow">$1</a>');
    return h;
  }
  function bubble(cls: "msg-coco" | "msg-user", html: string): HTMLDivElement {
    const d = document.createElement("div");
    d.className = cls;
    d.innerHTML = html;
    msgs.appendChild(d);
    msgs.scrollTop = msgs.scrollHeight;
    return d;
  }

  let busy = false;
  async function ask(q: string) {
    const text = q.trim();
    if (!text || busy) return;
    busy = true;
    sendBtn.disabled = true;
    input.value = "";
    input.style.height = "";
    $("coco-chips")?.remove(); // chips are a cold-start aid only
    bubble("msg-user", render(text));
    history.push({ role: "user", content: text });
    const t = bubble("msg-coco", '<span class="typing" role="status" aria-label="Coco is typing"><i></i><i></i><i></i></span>');
    try {
      const r = await fetch("/api/chat", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ messages: history, hotel }),
      });
      const data = await r.json();
      if (!r.ok || !data.content) throw new Error(data.error || "No reply");
      t.innerHTML = render(data.content);
      history.push({ role: "assistant", content: data.content });
    } catch {
      t.innerHTML = "Sorry — I hit a wave 🌊 Please try again in a moment, or reach Cyril on WhatsApp (+66 633 753 316).";
    } finally {
      busy = false;
      sendBtn.disabled = false;
      msgs.scrollTop = msgs.scrollHeight;
    }
  }

  form.addEventListener("submit", (e) => { e.preventDefault(); ask(input.value); });
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) { e.preventDefault(); ask(input.value); }
  });
  input.addEventListener("input", () => {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 112) + "px";
  });

  // ── Rail ⇄ sheet relocation ──
  const railSlot = document.getElementById("chat-rail-slot");
  const sheetSlot = $("chat-sheet-slot");
  const sheet = $("coco-sheet");
  const dock = $("coco-dock");
  const closeBtn = $("coco-sheet-close");
  const mq = matchMedia("(min-width: 1280px)");
  let lastFocus: HTMLElement | null = null;

  function inRail() { return mq.matches && !!railSlot; }
  function place() {
    (inRail() ? railSlot! : sheetSlot).appendChild(chat);
    dock.hidden = inRail();
    closeBtn.classList.toggle("grid", !inRail());
    closeBtn.classList.toggle("hidden", inRail());
    if (inRail()) closeSheet(false);
  }
  function openSheet() {
    if (inRail()) { input.focus(); return; }
    lastFocus = document.activeElement as HTMLElement;
    sheet.hidden = false;
    void sheet.offsetHeight; // force reflow so the slide-up transition runs
    sheet.classList.add("open");
    document.body.style.overflow = "hidden";
    input.focus();
  }
  function closeSheet(restore = true) {
    sheet.classList.remove("open");
    sheet.hidden = true;
    document.body.style.overflow = "";
    if (restore) lastFocus?.focus();
  }
  closeBtn.addEventListener("click", () => closeSheet());
  sheet.addEventListener("click", (e) => { if (e.target === sheet) closeSheet(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape" && !sheet.hidden) closeSheet(); });
  mq.addEventListener("change", place);
  place();

  // ── Global delegation: any [data-coco-q] asks, any [data-coco-open] opens ──
  document.addEventListener("click", (e) => {
    const el = (e.target as HTMLElement).closest<HTMLElement>("[data-coco-q],[data-coco-open]");
    if (!el) return;
    openSheet();
    const q = el.dataset.cocoQ;
    if (q) ask(q);
    else if (inRail()) input.focus();
  });
</script>
