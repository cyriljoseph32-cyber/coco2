---
import { SITE } from "../data/site";
const year = new Date().getFullYear();
---
<footer class="border-t hairline bg-ink-2 px-5 pb-8 pt-14 lg:px-8">
  <div class="mx-auto max-w-[1200px]">
    <div class="mb-10 grid grid-cols-2 gap-9 md:grid-cols-4 lg:grid-cols-5">
      <div class="col-span-2 md:col-span-4 lg:col-span-2">
        <div class="mb-2.5 text-[21px] font-extrabold tracking-tight text-white">🌴 Coco</div>
        <p class="max-w-[260px] text-[12.5px] leading-relaxed text-white/40">
          AI travel concierge for Koh Samui. Expert local answers for hotels, diving, tours, restaurants and everything in between — in 6 languages, 24/7.
        </p>
      </div>
      <nav aria-label="Product">
        <h2 class="mb-3.5 text-[10.5px] font-bold uppercase tracking-[2px] text-foam">Product</h2>
        <ul class="flex flex-col gap-2 text-[12.5px]">
          <li><a class="text-white/40 transition-colors hover:text-white" href="/how-it-works">How Coco works</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/hotels">For Hotels &amp; Villas</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/faq">FAQ</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/contact">Contact</a></li>
        </ul>
      </nav>
      <nav aria-label="Explore">
        <h2 class="mb-3.5 text-[10.5px] font-bold uppercase tracking-[2px] text-foam">Explore</h2>
        <ul class="flex flex-col gap-2 text-[12.5px]">
          <li><a class="text-white/40 transition-colors hover:text-white" href="/explore">All categories</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/beaches">Beaches</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/experiences">Experiences</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/guide">Practical guide</a></li>
        </ul>
      </nav>
      <nav aria-label="Contact">
        <h2 class="mb-3.5 text-[10.5px] font-bold uppercase tracking-[2px] text-foam">Contact</h2>
        <ul class="flex flex-col gap-2 text-[12.5px]">
          <li><a class="text-white/40 transition-colors hover:text-white" href={SITE.waLink("Hi Coco! I found you via the website 🌴")} target="_blank" rel="noopener">WhatsApp</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href={`mailto:${SITE.email}`}>{SITE.email}</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/privacy">Privacy Policy</a></li>
          <li><a class="text-white/40 transition-colors hover:text-white" href="/terms">Terms of Service</a></li>
        </ul>
      </nav>
    </div>

    <p class="mb-5 max-w-[760px] text-[11.5px] leading-relaxed text-white/35">
      Coco is free for travellers. Some activity and booking links are affiliate links (Viator, Klook, GetYourGuide, Booking.com) and Coco may earn a commission at no extra cost to you. Coco's answers are AI-generated and may be inaccurate — prices are indicative and not safety advice; always confirm with the operator.
    </p>

    <div class="flex flex-wrap items-center justify-between gap-2.5 border-t hairline pt-5 text-[11.5px] text-white/35">
      <span>© {year} Coco Concierge · Built with <span class="text-coral">♥</span> on Koh Samui, Thailand</span>
      <span>Powered by AI · All prices in THB</span>
    </div>
  </div>
</footer>
