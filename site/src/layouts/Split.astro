---
/**
 * Split viewport: scrolling content column + FIXED chat rail (desktop ≥1280px).
 * The rail never scrolls with the page — key product rule.
 * ChatPanel (rendered by Base) relocates itself into #chat-rail-slot.
 */
---
<div class="mx-auto grid max-w-[1440px] grid-cols-1 xl:grid-cols-[minmax(0,1fr)_minmax(400px,42%)]">
  <div class="min-w-0 px-5 pb-24 sm:px-8 lg:px-10 xl:pb-0 xl:pr-6">
    <slot />
  </div>
  <div class="hidden xl:block">
    <div class="sticky top-16 h-[calc(100dvh-var(--nav-h))] py-5 pl-2 pr-6">
      <div id="chat-rail-slot" class="h-full [&>#coco-chat]:h-full"></div>
    </div>
  </div>
</div>
