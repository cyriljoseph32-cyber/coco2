---
import Base from "../layouts/Base.astro";
import Split from "../layouts/Split.astro";
import { BEACHES } from "../data/beaches";

const chips = [
  { label: "👨‍👩‍👧 Family pick", q: "Best beach for families with young kids on Koh Samui?" },
  { label: "💎 Hidden gems", q: "Which hidden or quiet beaches on Koh Samui are worth the trip?" },
  { label: "🌅 Best sunset", q: "Where is the best sunset beach on Koh Samui?" },
  { label: "🏊 Swimming now", q: "Which Koh Samui beaches have the best swimming conditions this month?" },
];
const schema = [{
  "@type": "ItemList",
  name: "The 12 beaches of Koh Samui",
  itemListElement: BEACHES.map((b, i) => ({
    "@type": "ListItem", position: i + 1,
    item: { "@type": "Beach", name: `${b.name} Beach`, description: b.desc, address: { "@type": "PostalAddress", addressLocality: "Koh Samui", addressCountry: "TH" } },
  })),
}];
const zones = ["North", "Northeast", "East", "Southeast", "South", "Southwest", "West", "Northwest"];
---
<Base
  title="The 12 Beaches of Koh Samui — Compared by Vibe & Zone | Coco"
  description="Chaweng to Laem Set: every Koh Samui beach compared — who each is best for, swimming conditions, vibe and zone. Ask Coco for live details on any of them."
  chips={chips}
  schema={schema}
>
  <Split>
    <section class="py-16" aria-labelledby="h1">
      <p class="sec-num mb-5">COAST GUIDE</p>
      <h1 id="h1" class="font-display max-w-[16ch] text-[clamp(2.2rem,5vw,3.6rem)] font-medium leading-[1.06] tracking-[-0.02em] text-white">
        Twelve beaches, twelve personalities.
      </h1>
      <p class="mt-5 max-w-[50ch] text-[16px] leading-relaxed text-white/60">
        Clockwise from the famous east coast to the quiet south. Tap any beach and Coco gives you live details — facilities, conditions, and who it suits.
      </p>
    </section>

    <section class="border-t hairline py-12" aria-label="All beaches">
      <ul class="space-y-3">
        {BEACHES.map((b, i) => (
          <li>
            <button type="button" data-coco-q={b.slugQ} class="group grid w-full cursor-pointer grid-cols-[64px_1fr] gap-4 rounded-2xl border hairline bg-ink-2 p-4 text-left transition hover:border-foam/40 sm:grid-cols-[80px_1fr_auto] sm:items-center">
              <span class="h-full min-h-16 w-full rounded-xl" style={`background:linear-gradient(160deg,${b.grad[0]},${b.grad[1]})`} aria-hidden="true"></span>
              <span>
                <span class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
                  <span class="font-display text-[19px] font-semibold text-white">{String(i + 1).padStart(2, "0")} · {b.name}</span>
                  <span class="text-[11px] font-semibold uppercase tracking-[0.14em] text-foam/80">{b.zone}</span>
                </span>
                <span class="mt-1.5 block max-w-[62ch] text-[13px] leading-relaxed text-white/55">{b.desc}</span>
                <span class="mt-2 block text-[12px] text-sand/90">Best for: {b.bestFor}</span>
              </span>
              <span class="hidden text-[12.5px] font-semibold text-foam sm:block">Ask Coco →</span>
            </button>
          </li>
        ))}
      </ul>
    </section>

    <section class="border-t hairline py-12" aria-label="Zones">
      <p class="text-[13px] text-white/45">Zones covered: {zones.join(" · ")} — <button type="button" data-coco-q="Which zone of Koh Samui should I stay in — compare all the coasts for me." class="cursor-pointer font-semibold text-foam hover:underline">ask Coco to compare zones →</button></p>
    </section>
  </Split>
</Base>
