---
import Base from "../layouts/Base.astro";
---
<Base title="Page not found — Coco Samui" description="This page drifted out to sea. Ask Coco instead — it knows every corner of Koh Samui.">
  <section class="mx-auto flex min-h-[60dvh] max-w-[820px] flex-col items-start justify-center px-5 py-16 sm:px-8">
    <p class="sec-num mb-5">404</p>
    <h1 class="font-display text-[clamp(2.2rem,5vw,3.6rem)] font-medium leading-[1.06] tracking-[-0.02em] text-white">
      This page drifted out to sea. 🌊
    </h1>
    <p class="mt-5 max-w-[46ch] text-[16px] leading-relaxed text-white/60">
      But Coco knows every corner of the island — ask it anything, or head back to shore.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <button type="button" data-coco-open class="cursor-pointer rounded-xl bg-teal px-6 py-3.5 text-[15px] font-semibold text-white transition hover:bg-teal-deep">💬 Ask Coco</button>
      <a href="/" class="rounded-xl border hairline px-6 py-3.5 text-[15px] font-medium text-white/70 hover:text-white">← Back home</a>
    </div>
  </section>
</Base>
