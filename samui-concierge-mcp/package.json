{
  "name": "samui-concierge-mcp-server",
  "version": "1.0.0",
  "description": "MCP server that enriches the Coco Koh Samui concierge with live listings from Google Places, Viator, TripAdvisor, plus Klook/GetYourGuide affiliate links.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "samui-concierge-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
